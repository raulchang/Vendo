{
  "version": 2,
  "outputDirectory": ".",
  "crons": [
    {
      "path": "/api/admin-action",
      "schedule": "0 8 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(self)" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/public/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "routes": [
    { "src": "/api/stripe-webhook", "dest": "/api/stripe-webhook" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/script-vendo.html", "dest": "/script-vendo.html" },
    { "src": "/design-preview.html", "dest": "/design-preview.html" },
    { "src": "/sw\\.js", "dest": "/sw.js" },
    { "src": "/manifest\\.json", "dest": "/public/manifest.json" },
    { "src": "/apple-icon\\.png", "dest": "/public/apple-icon.png" },
    { "src": "/icon-(.*)\\.png", "dest": "/public/icon-$1.png" },
    { "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
